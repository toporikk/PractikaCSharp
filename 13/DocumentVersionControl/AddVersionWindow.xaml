<Window x:Class="DocumentVersionControl.AddVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление новой версии" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Номер версии:"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="VersionNumberBox" Margin="0,5"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Описание:"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DescriptionBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Путь к файлу:"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
            <TextBox x:Name="FilePathBox" Width="300" Margin="0,0,5,0"/>
            <Button x:Name="BrowseButton" Content="Обзор..." Width="60" Click="BrowseButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>