<Window x:Class="DocumentVersionControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DocumentVersionControl.ViewModels"
        xmlns:models="clr-namespace:DocumentVersionControl.Models"
        mc:Ignorable="d"
        Title="Система контроля версий документов" Height="550" Width="900"
        Focusable="True">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" InputGestureText="Alt+F4" Click="ExitClick"/>
            </MenuItem>
            <MenuItem Header="Документы">
                <MenuItem Header="Добавить версию" InputGestureText="Ctrl+N" Command="{Binding AddVersionCommand}"/>
                <MenuItem Header="Просмотреть историю" InputGestureText="Ctrl+H" Command="{Binding ViewHistoryCommand}"/>
                <MenuItem Header="Удалить версию" InputGestureText="Ctrl+D" Command="{Binding DeleteVersionCommand}"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem Header="О программе" Click="AboutClick"/>
            </MenuItem>
        </Menu>

        <!-- ToolBar -->
        <ToolBar Grid.Row="1">
            <Button Command="{Binding AddVersionCommand}" ToolTip="Добавить версию (Ctrl+N)">
                <TextBlock Text="➕ Добавить версию (Ctrl+N)"/>
            </Button>
            <Button Command="{Binding ViewHistoryCommand}" ToolTip="Просмотреть историю (Ctrl+H)">
                <TextBlock Text="📋 История (Ctrl+H)"/>
            </Button>
            <Button Command="{Binding DeleteVersionCommand}" ToolTip="Удалить версию (Ctrl+D)">
                <TextBlock Text="❌ Удалить версию (Ctrl+D)"/>
            </Button>
        </ToolBar>

        <!-- Контент с анимацией загрузки -->
        <Grid Grid.Row="2">
            <!-- Анимация загрузки -->
            <Border Background="#CCFFFFFF" 
                    VerticalAlignment="Stretch" 
                    HorizontalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLoading}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding LoadingMessage}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#FF2196F3"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="⏳" 
                               FontSize="48" 
                               HorizontalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                            Storyboard.TargetName="SpinnerRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:1" 
                                            RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="Загрузка версий..." 
                               FontSize="14" 
                               Foreground="#FF757575"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- TreeView для отображения структуры версий -->
            <TreeView Margin="10"
                      Background="White"
                      BorderBrush="#FFE0E0E0"
                      BorderThickness="1">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLoading}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>

                <TreeViewItem Header="📁 Документы" IsExpanded="True">
                    <TreeViewItem Header="Текущий документ" IsExpanded="True">
                        <TreeViewItem ItemsSource="{Binding Versions}">
                            <TreeViewItem.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type models:VersionModel}">
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="📄 " FontSize="14"/>
                                        <TextBlock Text="{Binding VersionNumber}" 
                                                   FontWeight="Bold" 
                                                   Foreground="#FF2E7D32"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding CreatedDate, StringFormat='dd.MM.yyyy'}" 
                                                   Foreground="#FF757575"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="#FF424242"
                                                   FontStyle="Italic"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeViewItem.ItemTemplate>
                        </TreeViewItem>
                    </TreeViewItem>
                </TreeViewItem>
            </TreeView>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText, Mode=OneWay, FallbackValue='Готов к работе'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>