<Window x:Class="DocVersionControl.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат обсуждения документа"
        Width="550" Height="500"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="#2196F3" CornerRadius="8" Padding="12" Margin="0,0,0,10">
			<TextBlock x:Name="lblDocName" Foreground="White" FontSize="14" FontWeight="Bold"
                       TextAlignment="Center"/>
		</Border>

		<ListBox x:Name="lstMessages" Grid.Row="1" Margin="0,0,0,10">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border Margin="5" Padding="10" CornerRadius="8" Background="#F0F0F0">
						<StackPanel>
							<TextBlock FontWeight="Bold" FontSize="11" Foreground="#2196F3"
                                       Text="{Binding Sender}"/>
							<TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,3,0,3"
                                       Text="{Binding Content}"/>
							<TextBlock FontSize="9" Foreground="Gray"
                                       Text="{Binding Timestamp}"/>
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<TextBox x:Name="txtMessage" Grid.Column="0" Height="70"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" Padding="5" FontSize="12"/>

			<Button x:Name="btnSend" Grid.Column="1" Content="📨 Отправить"
                    Width="90" Height="70" Margin="8,0,0,0" Click="btnSend_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    Cursor="Hand"/>
		</Grid>
	</Grid>
</Window>