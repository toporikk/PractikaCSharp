<Window x:Class="DocVersionControl.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система контроля версий - Вход"
        Width="400" Height="370"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

	<Border Background="White" CornerRadius="10" Padding="20" Height="360" VerticalAlignment="Top">
		<StackPanel>
			<TextBlock Text="📄 СИСТЕМА КОНТРОЛЯ ВЕРСИЙ"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<TextBlock Text="Логин:" Margin="0,0,0,5" FontSize="14"/>
			<TextBox x:Name="txtUsername" Height="35" Margin="0,0,0,15"
                     FontSize="14" Padding="5"/>

			<TextBlock Text="Пароль:" Margin="0,0,0,5" FontSize="14"/>
			<PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,25"
                         FontSize="14"/>

			<Button x:Name="btnLogin" Content="Войти" Height="40"
                    FontSize="14" FontWeight="Bold" Click="btnLogin_Click"
                    Background="#2196F3" Foreground="White" Cursor="Hand"/>

			<Button x:Name="btnRegister" Content="Регистрация" Height="35"
                    FontSize="13" Click="btnRegister_Click" Margin="0,10,0,0"
                    Background="Transparent" BorderBrush="#2196F3"
                    Foreground="#2196F3" Cursor="Hand"/>

			<TextBlock x:Name="lblError" Foreground="Red" Margin="0,10,0,0"
                       HorizontalAlignment="Center" FontSize="12"/>
		</StackPanel>
	</Border>
</Window>