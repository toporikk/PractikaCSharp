<Window x:Class="DocVersionControl.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Width="400" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

	<Border Background="White" CornerRadius="10" Padding="20">
		<StackPanel>
			<TextBlock Text="📝 РЕГИСТРАЦИЯ"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<TextBlock Text="Логин (мин. 3 символа):" Margin="0,0,0,5" FontSize="14"/>
			<TextBox x:Name="txtUsername" Height="35" Margin="0,0,0,15"
                     FontSize="14" Padding="5"/>

			<TextBlock Text="Пароль (мин. 3 символа):" Margin="0,0,0,5" FontSize="14"/>
			<PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,25"
                         FontSize="14"/>

			<Button x:Name="btnRegister" Content="Зарегистрироваться" Height="40"
                    FontSize="14" FontWeight="Bold" Click="btnRegister_Click"
                    Background="#4CAF50" Foreground="White" Cursor="Hand"/>

			<TextBlock x:Name="lblError" Foreground="Red" Margin="0,10,0,0"
                       HorizontalAlignment="Center" FontSize="12"/>
		</StackPanel>
	</Border>
</Window>