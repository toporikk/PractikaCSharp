<Window x:Class="DocVersionControl.AddVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление версии"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

	<Border Background="White" CornerRadius="10" Padding="20">
		<StackPanel>
			<TextBlock Text="➕ НОВАЯ ВЕРСИЯ"
                       FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<TextBlock Text="Номер версии:" Margin="0,0,0,5" FontSize="14"/>
			<TextBox x:Name="txtNumber" Margin="0,0,0,15" Height="35"
                     FontSize="14" Padding="5" Text="v1.0"/>

			<TextBlock Text="Описание изменений:" Margin="0,0,0,5" FontSize="14"/>
			<TextBox x:Name="txtDescription" TextWrapping="Wrap"
                     AcceptsReturn="True" Margin="0,0,0,25" Height="120"
                     FontSize="12" Padding="5" VerticalScrollBarVisibility="Auto"/>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Content="✅ Сохранить версию" Width="130" Height="35" Margin="0,0,10,0"
                        Click="btnOk_Click" Background="#FF9800" Foreground="White"
                        FontWeight="Bold" Cursor="Hand"/>
				<Button Content="❌ Отмена" Width="80" Height="35" Click="btnCancel_Click"
                        Background="#F44336" Foreground="White" Cursor="Hand"/>
			</StackPanel>
		</StackPanel>
	</Border>
</Window>